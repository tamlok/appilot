<?xml version="1.0" encoding="utf-8"?>
<!-- THROWAWAY spike manifest — Wave 0. Deleted in Task 2. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Resolve the two vendor packages WITHOUT QUERY_ALL_PACKAGES. -->
    <queries>
        <package android:name="com.tuya.smartiot" />
        <package android:name="com.haier.uhome.uplus" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="thingSmart" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="uplus" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:label="Launch Spike"
        android:supportsRtl="true">
        <activity
            android:name=".SpikeActivity"
            android:exported="true"
            android:label="Launch Spike">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
