# Normalize all text files to LF in the repository, check out LF on every platform.
* text=auto eol=lf

# Windows-only scripts must keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Gradle wrapper script must be LF so it runs on Linux/macOS/CI.
gradlew text eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.jar   binary
*.keystore binary
*.jks   binary
*.aab   binary
*.apk   binary
*.hprof binary
