<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only manifest overlay. Registers the actuate-layer QA harness Activity so
  it exists ONLY in debug builds and never reaches the release/product surface.
  Merged into the main manifest for the debug variant.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <activity
            android:name=".actuate.harness.TapHarnessActivity"
            android:exported="true"
            android:label="Tap Harness"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <!--
          Orchestration-layer (Wave 6) QA harness pair. Explicit, exported
          components so a CapturedShortcut/explicit-component LaunchTarget can
          replay them like a real vendor screen. HarnessSourceActivity draws a
          settable temperature graphic (read via projection+template);
          HarnessAcActivity counts real taps.
        -->
        <activity
            android:name=".service.harness.HarnessSourceActivity"
            android:exported="true"
            android:label="Harness Source"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />
        <activity
            android:name=".service.harness.HarnessAcActivity"
            android:exported="true"
            android:label="Harness AC"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />
    </application>

</manifest>
