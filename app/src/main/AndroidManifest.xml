<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Read layer (Wave 3) - MediaProjection single-frame capture. Android 14+
      requires a foreground service of type mediaProjection to be running before
      getMediaProjection(); FOREGROUND_SERVICE_MEDIA_PROJECTION gates that type,
      and POST_NOTIFICATIONS lets the FGS show its mandatory notification on 33+.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Scoped package visibility (targetSdk 36 / Android 11+). We deliberately do
      NOT request QUERY_ALL_PACKAGES: the picker only needs to see launchable
      apps and shortcut-creator activities the user can choose from.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.CREATE_SHORTCUT" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Appilot">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Appilot"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Read layer: hosts the system MediaProjection consent dialog. -->
        <activity
            android:name=".read.projection.ProjectionConsentActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Read layer: mediaProjection FGS that grabs a single frame on demand. -->
        <service
            android:name=".read.projection.ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!--
          Actuate layer (Wave 4): coordinate-only gesture tapper. The system binds
          it, so it REQUIRES the BIND_ACCESSIBILITY_SERVICE permission; the
          meta-data points at the config that sets canPerformGestures="true".
        -->
        <service
            android:name=".actuate.RegulatorAccessibilityService"
            android:exported="false"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>

</manifest>