<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Read layer (Wave 3) - MediaProjection single-frame capture. Android 14+
      requires a foreground service of type mediaProjection to be running before
      getMediaProjection(); FOREGROUND_SERVICE_MEDIA_PROJECTION gates that type,
      and POST_NOTIFICATIONS lets the FGS show its mandatory notification on 33+.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Orchestration layer (Wave 6) - RegulatorService runs the timed cycle as a
      foreground service of types specialUse + mediaProjection. specialUse needs
      its own runtime permission; mediaProjection reuses the perm declared above.
      REQUEST_IGNORE_BATTERY_OPTIMIZATIONS backs the Doze-exemption prompt so the
      AlarmManager loop keeps its exact cadence.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!--
      Scoped package visibility (targetSdk 36 / Android 11+). We deliberately do
      NOT request QUERY_ALL_PACKAGES: the picker only needs to see launchable
      apps and shortcut-creator activities the user can choose from.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.CREATE_SHORTCUT" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Appilot">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Appilot"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Calibration UI (Wave 7): hosts the source/actuator wiring flow. -->
        <activity
            android:name=".ui.calibration.CalibrationActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.Appilot"
            android:windowSoftInputMode="adjustResize" />

        <!-- Read layer: hosts the system MediaProjection consent dialog. -->
        <activity
            android:name=".read.projection.ProjectionConsentActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Read layer: mediaProjection FGS that grabs a single frame on demand. -->
        <service
            android:name=".read.projection.ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!--
          Actuate layer (Wave 4): coordinate-only gesture tapper. The system binds
          it, so it REQUIRES the BIND_ACCESSIBILITY_SERVICE permission; the
          meta-data points at the config that sets canPerformGestures="true".
        -->
        <service
            android:name=".actuate.RegulatorAccessibilityService"
            android:exported="false"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!--
          Orchestration layer (Wave 6): the timed cycle foreground service. It
          declares BOTH specialUse and mediaProjection FGS types - promoting from
          specialUse (started immediately) to mediaProjection only once a cycle is
          about to capture. The PROPERTY_SPECIAL_USE_FGS_SUBTYPE value justifies
          the specialUse type to the platform (no narrower built-in type fits a
          periodic, user-configured cross-app read+actuate loop).
        -->
        <service
            android:name=".service.RegulatorService"
            android:exported="false"
            android:foregroundServiceType="specialUse|mediaProjection">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="periodic user-configured AC temperature regulation: reads a designated screen and actuates a designated remote on a timer" />
        </service>
    </application>

</manifest>